agent "weather" {
  description = "Answers weather questions for a location and date"

  model         = model.fast
  system_prompt = prompt.weather_system

  tools = [tool.web_search]

  input "location" {
    type        = string
    description = "The location to get the weather for"
  }

  input "date" {
    type     = string
    optional = true
  }

  # Implicit dependency edge: weather -> forecast (deep reference,
  # collapses to the owning block per #8)
  input "forecast_context" {
    type    = string
    default = agent.forecast.output.summary
  }

  output "weather" {
    type = string
  }

  # Explicit ordering edge without data flow: weather -> geocoder
  depends_on = [agent.geocoder]
}
